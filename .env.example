PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=2
# Optional passive bot tuning (see passive_liquidity/config_manager.py)
# PASSIVE_BASE_SIZE=10
# PASSIVE_LOOP_INTERVAL=2
# PASSIVE_MAX_QUOTE_TASKS=30
# PASSIVE_QUOTE_ALL_TOKENS=true
# 启动时目录只打印前 N 条（0 或不写=不限制，列表会很长）
# PASSIVE_CATALOG_MAX_ROWS=300
# 交互目录每页条数（每条占 2 行） 
# PASSIVE_CATALOG_PAGE_SIZE=25
TELEGRAM_TOTAL_DEPOSITED_USDC=
# Telegram 通知：把 Bot Token 和群组 Chat ID 写在下面（从 @BotFather 取 token；群组 id 可用 @userinfobot 或 getUpdates 查看，一般为负数如 -100xxxxxxxxxx）
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ACCOUNT_LABEL=Polymarket账号1
TELEGRAM_NOTIFY_COOLDOWN_SEC=30

# =============================================================================
# 被动监控：盘口「成交活跃度 / 被吃风险」与深度占比（与主循环监控一致；不影响调价）
# — PASSIVE_ALERT_MONITORING=false 只关这类告警，不关下面「账户订单成交通知」
# Depth：depth_ratio > PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD 即触发
# 成交活跃度：fill_rate / 短窗成交笔数等任一超阈即触发；再经 PASSIVE_ALERT_COOLDOWN_SEC 去重
# =============================================================================
PASSIVE_ALERT_MONITORING=false
# 账户订单在 CLOB 上部分/全部成交时的 Telegram（事件: 订单成交）；与 PASSIVE_ALERT_MONITORING 无关
PASSIVE_TELEGRAM_NOTIFY_FILL=true
PASSIVE_TELEGRAM_NOTIFY_PARTIAL_FILL=false
PASSIVE_TELEGRAM_NOTIFY_FULL_FILL=false
PASSIVE_ALERT_COOLDOWN_SEC=120
PASSIVE_MONITOR_SHORT_TRADE_LOOKBACK_SEC=180 
PASSIVE_ALERT_FILL_RATE_THRESHOLD=0.35
PASSIVE_ALERT_SHORT_TRADES_THRESHOLD=8
PASSIVE_ALERT_FILL_RISK_SCORE_THRESHOLD=0.45
PASSIVE_ALERT_DIRECTION_IMBALANCE_MIN=0.62
PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD=0.7
PASSIVE_ALERT_SIG_FILL_RATE_DELTA=0.08
PASSIVE_ALERT_SIG_SHORT_TRADES_DELTA=4
PASSIVE_ALERT_SIG_FILL_RISK_DELTA=0.08
PASSIVE_ALERT_SIG_ADVERSE_SHARE_DELTA=0.07
PASSIVE_ALERT_SIG_DEPTH_RATIO_DELTA=0.05

# fill_rate 长窗口与分母（与 Fill 风险告警中的 fill_rate 相关）
PASSIVE_FILL_LOOKBACK_SEC=3600
PASSIVE_FILL_DENOM=25

# 未设置 PASSIVE_TOKEN_WHITELIST 时，用未成交单刷新白名单的间隔（秒）
PASSIVE_WHITELIST_REFRESH_SEC=120

# -----------------------------------------------------------------------------
# Telegram 交互配置自定义调价：/set_rule <order_id>（需 TELEGRAM_COMMANDS_ENABLED 未关闭）
# 规则按 token_id + BUY/SELL 持久化；默认文件见下，可改路径
# PASSIVE_CUSTOM_RULES_PATH=
# -----------------------------------------------------------------------------
# 默认调价：=true 时，凡未在 Telegram 保存规则的挂单，一律按下面 PASSIVE_CUSTOM_* 执行（内置粗/细策略关闭）
# 与 PASSIVE_CUSTOM_ORDER_IDS 可同时用；已保存 /set_rule 的 token+方向仍优先用持久化规则
# PASSIVE_DEFAULT_CUSTOM_PRICING=false
# 自定义调价（可选）：仅当上一项为 false 且未保存规则时，只有列在列表中的 order id 才走 PASSIVE_CUSTOM_*
# 订单 id 与 CLOB 返回的 id 完全一致，逗号分隔
# 自定义粗/细 tick 与主程序 classify_tick_regime 一致：≈0.01|1.0 粗，≈0.1|0.001 细
# PASSIVE_CUSTOM_ORDER_IDS=
# PASSIVE_CUSTOM_COARSE_TICK_OFFSET=1
# 粗 tick：N 只在激励带内「订单簿同侧有深度的价位」上从离 mid 最近往外数；无挂单的空 tick 不计入
# PASSIVE_CUSTOM_COARSE_ALLOW_TOP_OF_BOOK=true
# PASSIVE_CUSTOM_COARSE_MIN_CANDIDATES=1
# PASSIVE_CUSTOM_FINE_SAFE_MIN=0.4
# PASSIVE_CUSTOM_FINE_SAFE_MAX=0.6
# PASSIVE_CUSTOM_FINE_TARGET_RATIO=0.5
# -----------------------------------------------------------------------------
# Web 控制台（可选）：浏览器里查看状态/挂单/盈亏、撤单、编辑自定义规则 JSON
# 与机器人共用 .env；务必使用强随机 WEB_PANEL_TOKEN，且默认仅监听本机
# WEB_PANEL_TOKEN=
# 仅本机浏览器：127.0.0.1；要从别的机器用 IP 访问：0.0.0.0（须放行防火墙/安全组，风险高）
# WEB_PANEL_HOST=127.0.0.1
# WEB_PANEL_PORT=8765
# WEB_PANEL_SECRET_KEY=
# 启动: python run_web_panel.py
# -----------------------------------------------------------------------------
